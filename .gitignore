# Sensitive files
.env
auth.json
*.db
*.db-shm
*.db-wal

# Cache and temp files
cache/
audio_cache/
image_cache/
logs/
sessions/
cron/*
!cron/jobs.json
sandboxes/

# Process files
gateway.pid
processes.json

# Other sensitive
channel_directory.json
feishu_seen_message_ids.json
gateway_state.json
interrupt_debug.log
.skills_prompt_snapshot.json
.update_check

# Binary/cache directories
.bin/
.whatsapp/
.claude/
.pairing/
.pastes/
.checkpoints/

# Large trees never meant for Git backup
migration/
workspaces/
checkpoints/

# Nested git repo placeholder should stay as gitlink only
hermes-agent/

# Profile runtime data
profiles/*/cache/
profiles/*/audio_cache/
profiles/*/image_cache/
profiles/*/logs/
profiles/*/sessions/
profiles/*/sandboxes/
profiles/*/cron/output/
profiles/*/cron/.tick.lock
profiles/*/state.db
profiles/*/state.db-shm
profiles/*/state.db-wal

# Account/session runtime artifacts
weixin/accounts/*.context-tokens.json
weixin/accounts/*.sync.json
.hermes_history
.env.bak
auth.lock
config.yaml.bak